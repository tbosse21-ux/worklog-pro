import 'package:flutter/material.dart';

void main() {
  runApp(const WorkLogProApp());
}

class WorkLogProApp extends StatelessWidget {
  const WorkLogProApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'WorkLog Pro',
      debugShowCheckedModeBanner: false,
      theme: ThemeData(
        colorSchemeSeed: const Color(0xFF0D47A1),
        useMaterial3: true,
        scaffoldBackgroundColor: Colors.white,
      ),
      home: const HomePage(),
    );
  }
}

class HomePage extends StatelessWidget {
  const HomePage({super.key});

  Widget menuButton(
    BuildContext context,
    IconData icon,
    String text,
  ) {
    return Padding(
      padding: const EdgeInsets.symmetric(vertical: 8),
      child: SizedBox(
        width: double.infinity,
        height: 65,
        child: ElevatedButton.icon(
          icon: Icon(icon, size: 28),
          label: Text(
            text,
            style: const TextStyle(
              fontSize: 20,
              fontWeight: FontWeight.bold,
            ),
          ),
          onPressed: () {},
        ),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text("WorkLog Pro"),
        centerTitle: true,
      ),
      body: Padding(
        padding: const EdgeInsets.all(20),
        child: Column(
          children: [

            const SizedBox(height: 20),

            const Text(
              "Willkommen",
              style: TextStyle(
                fontSize: 28,
                fontWeight: FontWeight.bold,
              ),
            ),

            const SizedBox(height: 40),

            menuButton(
              context,
              Icons.description,
              "Neuer Arbeitsbericht",
            ),

            menuButton(
              context,
              Icons.folder,
              "Offene Berichte",
            ),

            menuButton(
              context,
              Icons.people,
              "Kunden",
            ),

            menuButton(
              context,
              Icons.settings,
              "Einstellungen",
            ),

            const Spacer(),

            const Text(
              "Version 0.1",
              style: TextStyle(color: Colors.grey),
            ),
          ],
        ),
      ),
    );
  }
}